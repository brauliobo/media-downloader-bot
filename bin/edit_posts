#!/usr/bin/env ruby

ENV['TD_BOT'] = '1'

require 'drb/drb'
require 'fileutils'
require 'tmpdir'

require_relative '../lib/manager'
require_relative '../lib/worker'

class EditPosts
  DEFAULT_LIMIT = 20
  DEFAULT_FETCH_LIMIT = 100

  class CaptureService
    include Bot::MsgHelpers

    attr_reader :uploads

    def initialize(bot)
      @bot     = bot
      @uploads = []
      @next_id = 1
    end

    def send_message(_msg, text = nil, type: 'message', parse_mode: 'MarkdownV2', **params)
      id = next_id
      @uploads << { text: text, type: type.to_s, parse_mode: parse_mode, params: params } if media_upload?(type, params)
      SymMash.new(message_id: id, result: { message_id: id }, text: text)
    end

    def edit_message(*)
      true
    end

    def delete_message(*)
      true
    end

    def download_file(*args, **kwargs)
      @bot.download_file(*args, **kwargs)
    end

    def report_error(_msg, error, context: nil)
      warn "error: #{context} #{error.class}: #{error.message}"
    end

    private

    def next_id
      @next_id += 1
    end

    def media_upload?(type, params)
      type.to_s.in?(%w[audio video document]) || params.key?(:audio_path) || params.key?(:video_path) || params.key?(:document_path)
    end
  end

  def initialize(argv)
    @opts = parse_opts(argv)
  end

  def run
    configure_worker_tmpdir

    manager = DRbObject.new_with_uri(drb_uri)
    chat    = resolve_chat(manager)
    posts = manager.chat_messages(chat_id: chat[:id], limit: fetch_limit, query: @opts[:query], filter: @opts[:media])
    posts = select_posts(posts).first(limit)

    puts "chat=#{chat[:id]} title=#{chat[:title].inspect} posts=#{posts.size} apply=#{apply?}"

    posts.each.with_index(1) do |post, index|
      source = source_post(manager, chat, post)
      puts "#{index}. post=#{post[:id]} type=#{post[:type]} source=#{source_label(source)}"
      next if plan?

      upload = select_upload(post, regenerate(manager, chat, post, source))
      if upload.nil?
        warn "  no generated upload captured"
        next
      end

      puts "  generated type=#{upload[:type]} file=#{upload[:params][:"#{upload[:type]}_path"] || upload[:params][:file_path]}"
      next unless apply?

      manager.edit_generated_message(
        chat_id:    chat[:id],
        message_id: post[:id],
        text:       upload[:text],
        type:       upload[:type],
        parse_mode: upload[:parse_mode],
        **upload[:params]
      )
      puts "  edited"
    end
  end

  private

  def configure_worker_tmpdir
    dir = @opts[:tmpdir] || File.join(Dir.pwd, 'tmp', 'edit_posts')
    FileUtils.mkdir_p(dir)
    Worker.tmpdir = dir
  end

  def parse_opts(argv)
    argv.each_with_object({}) do |arg, opts|
      key, value = arg.split('=', 2)
      opts[key.tr('-', '_').to_sym] = value || true
    end
  end

  def drb_uri
    @opts[:drb] || ENV['BOT_DRB'] || 'druby://127.0.0.1:1188'
  end

  def limit
    (@opts[:limit] || DEFAULT_LIMIT).to_i
  end

  def fetch_limit
    [limit, (@opts[:fetch_limit] || DEFAULT_FETCH_LIMIT).to_i].max
  end

  def order
    @opts[:order] || 'oldest'
  end

  def select_posts(posts)
    posts = posts.select { |post| generated_post?(post) } unless @opts[:all].to_s == '1'
    posts = posts.sort_by { |post| post[:id].to_i }
    posts.reverse! if order == 'newest'
    posts
  end

  def generated_post?(post)
    post[:reply_to_message_id].present? && post[:media].present?
  end

  def apply?
    @opts[:apply].to_s == '1'
  end

  def plan?
    @opts[:plan].to_s == '1'
  end

  def resolve_chat(manager)
    raw = @opts[:chat] || @opts[:channel] || abort('chat= or channel= is required')
    return { id: raw.to_i, title: raw, type: 'Chat' } if raw.to_s.match?(/\A-?\d+\z/)

    query = raw.to_s.delete_prefix('@')
    chats = manager.find_chats(query, limit: 10, public: @opts[:public].to_s == '1')
    abort "no chat found for #{raw.inspect}" if chats.empty?
    abort "multiple chats found; use chat=<id>: #{chats.inspect}" if chats.size > 1

    chats.first
  end

  def source_text(post)
    source = @opts[:source]
    return source.to_s if source

    text = post[:text].to_s.strip
    return text unless @opts[:source_urls].to_s == '1'

    text.scan(%r{https?://\S+}).join("\n")
  end

  def source_post(manager, chat, post)
    return post if @opts[:source]
    return post unless post[:reply_to_message_id]

    reply = manager.chat_message(chat_id: chat[:id], message_id: post[:reply_to_message_id])
    source_usable?(reply) ? reply : post
  end

  def source_usable?(post)
    source_text(post).present? || post[:media].present?
  end

  def source_label(post)
    media = post[:media]
    text  = source_text(post)
    parts = ["message=#{post[:id]}", "type=#{post[:type]}"]
    parts << "media=#{media[:kind]}:#{media[:file_name]}" if media
    parts << "text=#{text.inspect}" if text.present?
    parts.join(' ')
  end

  def regenerate(manager, chat, post, source_post)
    service = CaptureService.new(manager)
    old_service = Worker.service
    old_skip_cleanup = Worker.skip_cleanup
    Worker.service = service
    Worker.skip_cleanup = true

    text = worker_text(source_post)

    msg = SymMash.new(
      id:      source_post[:id] || post[:id],
      text:    text,
      caption: text,
      chat:    { id: chat[:id] },
      from:    { id: ENV['ADMIN_CHAT_ID'].to_i }
    )

    if (media = source_post[:media])
      msg[media[:kind].to_sym] = SymMash.new(
        file_id:   media[:file_id],
        file_name: media[:file_name],
        mime_type: media[:mime_type]
      )
    end

    Worker.new(msg).process
    service.uploads
  ensure
    Worker.service = old_service
    Worker.skip_cleanup = old_skip_cleanup
  end

  def select_upload(post, uploads)
    items  = Array(uploads)
    target = post.dig(:media, :kind).to_s

    items.find { |item| item[:type].to_s == target } || items.first
  end

  SCRIPT_OPT_KEYS = %i[
    all apply channel chat drb fetch_limit limit media order plan public query source source_urls tmpdir
  ].freeze

  def worker_text(post)
    text = source_text(post)
    opts = worker_opts_text
    [text, opts].reject(&:blank?).join("\n")
  end

  def worker_opts_text
    @opts.reject { |key, _value| SCRIPT_OPT_KEYS.include?(key) }
      .map { |key, value| value == true ? key.to_s : "#{key}=#{value}" }
      .join("\n")
  end
end

EditPosts.new(ARGV).run
