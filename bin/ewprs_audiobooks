#!/usr/bin/env ruby

require 'drb/drb'
require 'fileutils'
require 'json'
require 'time'
require_relative '../lib/boot'
require_relative '../lib/audiobook'
require_relative '../lib/audiobook/ewprs'
require_relative '../lib/audiobook/ewprs_batch'

$stdout.sync = true
$stderr.sync = true

opts = ARGV.each_with_object({}) do |arg, values|
  key, value = arg.split('=', 2)
  values[key.tr('-', '_').to_sym] = value || '1'
end

source  = opts[:source] || File.expand_path('../../eewprs', __dir__)
output  = File.expand_path(opts[:output] || 'tmp/ewprs_audiobooks', Dir.pwd)
ENV['EWPRS_VOICE_REFERENCE'] = opts[:voice_reference] if opts[:voice_reference]
catalog = Audiobook::Ewprs.new(source)

if opts[:dry_run].to_s == '1'
  audit = catalog.audit
  expected = { discourses: 1_611, available_discourses: 1_561, books: 140 }
  expected.each { |key, value| raise "#{key}: expected #{value}, got #{audit[key]}" unless audit[key] == value }
  puts JSON.pretty_generate(audit)
  exit
end

FileUtils.mkdir_p(output)

entries = if opts[:all].to_s == '1'
  catalog.available_discourses
else
  [catalog.find(opts[:only] || 'Laying_of_the_Foundation_Stone') || raise('audiobook not found')]
end
books = opts[:books].to_s == '1' ? catalog.books : []

if opts[:plan].to_s == '1'
  puts JSON.pretty_generate(
    output: output,
    discourses: entries.size,
    books: books.size,
    uploads: entries.size + books.size
  )
  exit
end

apply = opts[:apply].to_s == '1'
if apply
  manager = DRbObject.new_with_uri(opts[:drb] || ENV['BOT_DRB'] || 'druby://127.0.0.1:1188')
  chat_id = opts[:chat_id].to_i
  if chat_id.zero?
    chat    = manager.resolve_chat_identifier(opts[:channel] || '@prsarkar_readings')
    chat_id = chat[:id]
  else
    chat = {id: chat_id}
  end
  forum_topic_id = opts[:forum_topic_id].to_i
  topic = if forum_topic_id.zero?
    manager.ensure_forum_topic(chat_id: chat_id, name: opts[:topic] || 'English Audiobooks')
  else
    {forum_topic_id: forum_topic_id, name: opts[:topic] || 'English Audiobooks'}
  end
end
batch = Audiobook::EwprsBatch.new(
  catalog: catalog, output: output, jobs: opts[:jobs] || 5, manifest: opts[:manifest],
  manager: manager, chat_id: chat_id, topic: topic, apply: apply
)

if opts[:record_message_id]
  raise 'record-message-id requires exactly one audiobook' unless entries.one? && books.empty?

  puts JSON.pretty_generate(
    batch.record(entries.first, message_id: opts[:record_message_id], remote_id: opts[:record_remote_id])
  )
  exit
end

puts JSON.pretty_generate(batch.run(discourses: entries, books: books))
