                "PORT=10240 HOST=127.0.0.1 "
                "/home/braulio/Projects/F5-TTS/.venv/bin/python http_server.py",
            ),
        ),
    }


ALIASES = {
    "resemble": "chatterbox",
    "chatterbox_v3": "chatterbox",
    "f5": "f5tts",
    "f5-tts": "f5tts",
    "fs-tts": "f5tts",
    "fstts": "f5tts",
    "fish-speech": "fish",
}


def resolve_engine_names(raw: str, engines: dict[str, Engine]) -> list[str]:
    if raw.strip().lower() == "all":
        return ["omnivoice", "chatterbox", "piper", "fish", "f5tts", "coqui"]
    names = []
    for part in raw.split(","):
        name = ALIASES.get(part.strip().lower(), part.strip().lower())
        if name not in engines:
            raise SystemExit(f"Unknown engine: {part}")
        names.append(name)
    return names


def start_engine(engine: Engine, args: argparse.Namespace) -> None:
    if engine.health_url and http_available(engine.health_url, timeout=5):
        log(f"{engine.name} is already healthy")
        return

    if engine.spawn_cmd:
        log(f"Spawning {engine.name} without systemd")
        log_path = args.output_dir / f"{engine.name}-server.log"
        log_path.parent.mkdir(parents=True, exist_ok=True)
        log_file = log_path.open("ab")
        process = subprocess.Popen(
            engine.spawn_cmd,
            shell=True,
            stdout=log_file,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
        args.spawned_processes[engine.name] = (process, log_file)
        if engine.health_url:
            try:
                wait_http(engine.health_url, timeout=args.service_timeout)
                return
            except Exception:
                stop_engine(engine, args)
                raise
        time.sleep(float(env(shell_env_name(engine.name, "READY_DELAY"), "3")))
        return

    if args.manage_services:
        start_cmd = engine.resolved_start_cmd()
        if start_cmd:
            if systemd_command(start_cmd):
                log(f"Skipping systemd start command for {engine.name}")
            else:
                try:
                    run_shell(start_cmd, timeout=args.service_timeout)
                except subprocess.CalledProcessError:
                    if engine.health_url and http_available(engine.health_url, timeout=5):
                        log(f"{engine.name} start command failed, but health check is OK; continuing")
                    else:
                        raise
        elif engine.kind != "chatterbox":
            log(f"No start command configured for {engine.name}; assuming it is already available")
    if engine.health_url:
        wait_http(engine.health_url, timeout=args.service_timeout)


def stop_engine(engine: Engine, args: argparse.Namespace) -> None:
    spawned = args.spawned_processes.pop(engine.name, None)
    if spawned:
        process, log_file = spawned
        if process.poll() is None:
            log(f"Stopping spawned {engine.name} process")
            try:
                os.killpg(process.pid, signal.SIGTERM)
                process.wait(timeout=30)
            except subprocess.TimeoutExpired:
                os.killpg(process.pid, signal.SIGKILL)
                process.wait(timeout=30)
        log_file.close()
        return

    if not args.manage_services or args.keep_services:
        return
    if engine.name in args.keep_running_engines:
        log(f"Keeping {engine.name} running")
        return
    stop_cmd = engine.resolved_stop_cmd()
    if stop_cmd:
        if systemd_command(stop_cmd):
            log(f"Skipping systemd stop command for {engine.name}")
            return
        try:
            run_shell(stop_cmd, timeout=args.service_timeout)
        except subprocess.CalledProcessError as exc:
            log(f"WARNING: failed to stop {engine.name}: {exc}")


def evaluate_engine(engine: Engine, paragraphs: list[str], source_text: str, args: argparse.Namespace) -> dict[str, Any]:
    engine_dir = args.output_dir / engine.name
    engine_dir.mkdir(parents=True, exist_ok=True)
    paragraph_wavs: list[Path] = []
    timings: list[dict[str, Any]] = []

    for idx, paragraph in enumerate(paragraphs, 1):
        out_path = engine_dir / f"paragraph-{idx:02d}.wav"
        started = time.monotonic()
        engine.synthesize(paragraph, out_path, lang=args.lang)
        elapsed = time.monotonic() - started
        if not out_path.exists() or out_path.stat().st_size == 0:
            raise RuntimeError(f"{engine.name} did not create {out_path}")
        log(f"{engine.name}: paragraph {idx} synthesized in {elapsed:.2f}s")
        timings.append({"paragraph": idx, "seconds": elapsed})
        paragraph_wavs.append(out_path)

    combined_wav = engine_dir / f"{engine.name}-{args.lang}-combined.wav"
    duration = concat_wavs(paragraph_wavs, combined_wav, silence_s=args.paragraph_silence)
    whisper_json = whisper_transcribe(combined_wav, args.whisper_url, lang=args.lang)
    score = score_transcription(source_text, whisper_json)

    (engine_dir / "whisper.json").write_text(json.dumps(whisper_json, ensure_ascii=False, indent=2), encoding="utf-8")
    (engine_dir / "score.json").write_text(json.dumps(score, ensure_ascii=False, indent=2), encoding="utf-8")

    score.update(
        {
            "engine": engine.name,
            "wav_path": str(combined_wav),
            "duration_seconds": duration,
            "synthesis_timings": timings,
        }
    )
    return score


def write_summary_csv(results: dict[str, Any], path: Path) -> None:
    fields = [
        "engine",
        "expected_words",
        "recognized_words",
        "matching_words",
        "match_rate",
        "word_error_rate",
        "substitutions",
        "deletions",
        "insertions",
        "matched_word_confidence_mean",
        "mismatched_word_confidence_mean",
        "all_recognized_word_confidence_mean",
        "segment_confidence_from_avg_logprob_mean",
        "detected_language",
        "detected_language_probability",
        "duration_seconds",
        "wav_path",
    ]
    with path.open("w", newline="", encoding="utf-8") as file:
        writer = csv.DictWriter(file, fieldnames=fields)
        writer.writeheader()
        for item in results["engines"].values():
            writer.writerow({field: item.get(field) for field in fields})


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Compare TTS engines with whisper.cpp word confidence metrics")
    parser.add_argument("--engines", default="omnivoice,chatterbox,piper,fish,f5tts,coqui")
    parser.add_argument("--text-file", type=Path)
    parser.add_argument("--output-dir", type=Path, default=ROOT / "tmp/tts-eval")
    parser.add_argument("--lang", default="pt")
    parser.add_argument("--whisper-url", default=env("WHISPER_CPP_SERVER", "http://127.0.0.1:8080"))
    parser.add_argument("--manage-services", action="store_true", help="Run configured non-systemd start/stop commands around each engine")
    parser.add_argument("--keep-services", action="store_true", help="Do not stop services after evaluation")
    parser.add_argument(
        "--keep-running-engines",
        default=env("TTS_EVAL_KEEP_RUNNING_ENGINES"),
        help="Comma-separated engines that must not be stopped. Defaults to TTS from .env/ENV.",
    )
    parser.add_argument("--service-timeout", type=int, default=180)
    parser.add_argument("--paragraph-silence", type=float, default=0.35)
    parser.add_argument("--skip-unavailable", action="store_true", default=True)
    parser.add_argument("--require-all", action="store_true", help="Fail the whole run if any engine is unavailable")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    if args.require_all:
        args.skip_unavailable = False

    protected = args.keep_running_engines
    if protected is None:
        protected = default_tts_engine_name() or ""
    args.keep_running_engines = {
        ALIASES.get(item.strip().lower(), item.strip().lower())
        for item in protected.split(",")
        if item.strip()
    }

    source_text = args.text_file.read_text(encoding="utf-8") if args.text_file else DEFAULT_TEXT
    paragraphs = split_paragraphs(source_text)
    if not paragraphs:
        raise SystemExit("No text paragraphs found")

    args.output_dir.mkdir(parents=True, exist_ok=True)
    args.spawned_processes = {}
    (args.output_dir / "source.txt").write_text(source_text, encoding="utf-8")

    engines = default_engines()
    engine_names = resolve_engine_names(args.engines, engines)
    results: dict[str, Any] = {
        "source_text": source_text,
        "source_words": len(words_from_text(source_text)),
        "engines": {},
        "errors": {},
    }

    for name in engine_names:
        engine = engines[name]
        log(f"=== {engine.name} ===")
        try:
            start_engine(engine, args)
            results["engines"][engine.name] = evaluate_engine(engine, paragraphs, source_text, args)
        except Exception as exc:  # noqa: BLE001 - reported in machine-readable output
            results["errors"][engine.name] = str(exc)
            log(f"ERROR {engine.name}: {exc}")
            if not args.skip_unavailable:
                raise
        finally:
            stop_engine(engine, args)
            if shutil.which("nvidia-smi"):
                subprocess.run(["nvidia-smi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)

    results_path = args.output_dir / "results.json"
    results_path.write_text(json.dumps(results, ensure_ascii=False, indent=2), encoding="utf-8")
    write_summary_csv(results, args.output_dir / "summary.csv")
    print(json.dumps(results, ensure_ascii=False, indent=2))
    log(f"Wrote {results_path}")
    return 0 if results["engines"] else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
