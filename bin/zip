#!/usr/bin/env ruby

require 'fileutils'

STDOUT.sync = true
Process.setpriority(Process::PRIO_PROCESS, 0, 19)
ENV['SKIP_META'] = '1'
ENV['DB'] = '1' if ENV['SESSION_UID']
ENV['PUPPETEER_HEADLESS'] ||= '0'

Dir.chdir File.expand_path "#{File.realpath __dir__}/.." do
  require_relative '../lib/worker'
  require_relative '../lib/bot/base'
  require_relative '../lib/processors/folder'
end

opts  = SymMash.new metadata: {}
lopts = []
while ARGV[-1] and !File.exist?(ARGV[-1]) and ARGV[-1] !~ URI::regexp
  opt = ARGV.pop
  lopts.push opt
  Processors::Base.add_opt opts, opt
end

Zipper.size_mb_limit = ENV['SIZE_MB_LIMIT']&.to_i || 2_000

bot = Bot::Mock.new
Worker.service = bot

converted_dir = File.join(Dir.pwd, 'converted')
FileUtils.mkdir_p converted_dir
Worker.skip_cleanup = true

raise "No files found" if ARGV.blank?

if opts.langdetect
  path = ARGV.size > 1 ? ARGV : ARGV.first&.split("\n")
  path.each do |u|
    raise "Input not found: #{u}" unless File.exist?(u)

    puts "#{u}: #{Audiobook::Book.detect_language(u, opts: opts)}"
  end
  exit 0
end

if Processors::Folder.handles?(ARGV, opts)
  Processors::Folder.new(
    paths: ARGV,
    opts: opts,
    option_args: lopts,
    bot: bot,
  ).run
  exit 0
end

path = if ARGV.size > 1 then ARGV else ARGV.first&.split "\n" end
path.each do |u|
  fake_msg = Bot::MsgHelpers.fake_msg
  fake_msg.bot = bot

  # Handle local files
  if File.exist?(u)
    Worker.workdir_path = File.join(File.dirname(File.expand_path(u)), 'converted')
    FileUtils.mkdir_p Worker.workdir_path
    Processors::LocalFile.attach_to_message(fake_msg, u, opts: lopts)
  else
    Worker.workdir_path = converted_dir
    # Handle URLs
    line = u =~ URI::regexp ? "#{u} #{lopts.join ' '}" : u
    fake_msg.text = line
  end

  worker = Worker.new fake_msg
  worker.process
end
